# ============================================
# 照片足迹 (Photo Map) — 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填入实际值:
#   cp .env.example .env.local
#
# Docker 部署请复制为 .env.docker:
#   cp .env.example .env.docker
# ============================================

# ---------- 数据库 ----------
# PostgreSQL 连接字符串（本地开发用 localhost，Docker 用容器名）
DATABASE_URL="postgresql://user:password@localhost:5432/photomap_db"

# ---------- MinIO / S3 对象存储 ----------
# 外网地址（浏览器端访问，可填 MinIO 域名或 sso 子域名）
MINIO_ENDPOINT="https://sso.yourdomain.com"
# 内网地址（Docker 容器间通信，使用容器名，非 Docker 环境可留空）
MINIO_INTERNAL_ENDPOINT="http://photo-map-minio:9000"
MINIO_ACCESS_KEY="your_minio_access_key"
MINIO_SECRET_KEY="your_minio_secret_key"
MINIO_BUCKET="photo-map-bucket"
MINIO_REGION="us-east-1"

# ---------- 图片缓存 ----------
# 图片代理缓存的过期时间（秒），建议开发 3600，生产 604800（7 天）
IMAGE_EXPIRES_IN="3600"

# ---------- Ollama（本地 AI） ----------
# Docker 环境用 host.docker.internal 访问宿主机 Ollama
OLLAMA_BASE_URL="http://host.docker.internal:11434/api"

# ---------- 高德地图 API ----------
# 用于逆地理编码（坐标 → 地址）
# 申请地址: https://console.amap.com/dev/key/app
AMAP_API_KEY="your_amap_api_key"

# ---------- 管理员 ----------
# 用于生产环境 /admin 页面的简单密码校验
ADMIN_PASSWORD="your_admin_password"

# ---------- AI 模型配置 ----------
# 意图解析模型
INFERENCE_MODEL="qwen2.5:1.5b"
# 图片描述模型
IMAGE_DESC_MODEL="moondream"
# 翻译 & 关键词提取模型
TRANSLATE_MODEL="qwen2.5:1.5b"
# 向量嵌入模型（需支持 1024 维输出）
EMBEDDING_MODEL="bge-m3"

# ---------- 应用配置 ----------
NEXT_PUBLIC_APP_NAME="照片足迹"

# ---------- 地图（前端可访问） ----------
# 自建地图瓦片样式 URL（MapLibre Style JSON）
NEXT_PUBLIC_MAP_DARK_STYLE_URL="https://map.yourdomain.com/styles/dark/style.json"
NEXT_PUBLIC_MAP_BRIGHT_STYLE_URL="https://map.yourdomain.com/styles/bright/style.json"
# 默认地图中心点（经度,纬度）
NEXT_PUBLIC_MAP_DEFAULT_CENTER="116.39123,39.90703"
