generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"] // 开启PostgreSQL扩展功能
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector"), postgis] // 开启 pgvector 和 postgis 扩展
}

model PhotoExif {
  id                      Int     @id @default(autoincrement())
  photoId                 Int     @unique
  make                    String?
  model                   String?
  lensModel               String?
  fNumber                 Float?
  exposureTime            String?
  iso                     Int?
  focalLength             Float?
  exposureBias            Float?
  latitude                Float?
  longitude               Float?
  altitude                Float?
  colorSpace              String?
  exposureMode            String?
  exposureProgram         String?
  flash                   String?
  focalLengthIn35mmFormat Float?
  gpsTimeStamp            String?
  lensMake                String?
  meteringMode            String?
  rawData                 Json?
  software                String?
  whiteBalance            String?
  exifImageHeight         Int?
  exifImageWidth          Int?
  GPSLatitude             Int[]   @default([])
  GPSLatitudeRef          String?
  GPSLongitude            Int[]   @default([])
  GPSLongitudeRef         String?
  bearingDirection        String?
  gpsImgDirection         Float?
  photos                  Photo   @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@map("photo_exifs")
}

model Location {
  id               Int     @id @default(autoincrement())
  photoId          Int     @unique
  latitude         Float
  longitude        Float
  GPSLatitude      Int[]   @default([])
  GPSLongitude     Int[]   @default([])
  altitude         Float?
  bearing          Float?
  bearingDirection String?
  country          String?
  province         String?
  city             String?
  district         String?
  township         String?
  adcode           String?
  formattedAddress String?
  neighborhood     String?
  type             String?
  rawData          Json?
  photo            Photo   @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
  @@map("locations")
}

model Photo {
  id              Int              @id @default(autoincrement())
  filename        String
  originalPath    String           @unique
  size            Int
  mimeType        String
  originalKey     String
  thumbSmallKey   String
  thumbLargeKey   String
  videoKey        String?
  width           Int?
  height          Int?
  takenAt         DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now())
  dominantColor   String?
  top             Boolean          @default(false)
  photoExif       PhotoExif?
  location        Location?
  photoAiAnalysis PhotoAiAnalysis?

  @@map("photos")
}

model PhotoAiAnalysis {
  id                 Int                                    @id @default(autoincrement())
  photoId            Int                                    @unique @map("photo_id")
  description        String?
  chineseDescription String?                                @map("chinese_description")
  tags               String[]
  embedding          Unsupported("vector(768)")? // 向量字段
  location           Unsupported("geography(Point, 4326)")? // 地理坐标字段
  createdAt          DateTime                               @default(now()) @map("created_at")
  updatedAt          DateTime                               @default(now()) @updatedAt @map("updated_at")
  photo              Photo                                  @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@map("photo_ai_analyses")
}
