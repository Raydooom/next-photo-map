generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model photoExif {
  id                      Int     @id @default(autoincrement())
  photoId                 Int     @unique
  make                    String?
  model                   String?
  lensModel               String?
  fNumber                 Float?
  exposureTime            String?
  iso                     Int?
  focalLength             Float?
  exposureBias            Float?
  latitude                Float?
  longitude               Float?
  altitude                Float?
  colorSpace              String?
  exposureMode            String?
  exposureProgram         String?
  flash                   String?
  focalLengthIn35mmFormat Float?
  gpsTimeStamp            String?
  lensMake                String?
  meteringMode            String?
  rawData                 Json?
  software                String?
  whiteBalance            String?
  exifImageHeight         Int?
  exifImageWidth          Int?
  GPSLatitude             Int[]   @default([])
  GPSLatitudeRef          String?
  GPSLongitude            Int[]   @default([])
  GPSLongitudeRef         String?
  bearingDirection        String?
  gpsImgDirection         Float?
  photos                  photos  @relation(fields: [photoId], references: [id], onDelete: Cascade)
}

model locations {
  id               Int     @id @default(autoincrement())
  photoId          Int     @unique
  latitude         Float
  longitude        Float
  GPSLatitude      Int[]   @default([])
  GPSLongitude     Int[]   @default([])
  altitude         Float?
  bearing          Float?
  bearingDirection String?
  country          String?
  province         String?
  city             String?
  district         String?
  township         String?
  adcode           String?
  formattedAddress String?
  neighborhood     String?
  type             String?
  rawData          Json?
  photos           photos  @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
}

model photos {
  id            Int        @id @default(autoincrement())
  filename      String
  originalPath  String     @unique
  size          Int
  mimeType      String
  originalKey   String?
  thumbSmallKey String?
  thumbLargeKey String?
  videoKey      String?
  width         Int?
  height        Int?
  takenAt       DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now())
  dominantColor String?
  description   String?
  tags          String[]   @default([])
  photoExif     photoExif?
  locations     locations?
  top           Boolean    @default(false)
}
